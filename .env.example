# Copy to .env.local and fill with your Supabase project values
# (Project Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The shared temporary password handed out to all students for first login.
# Used by the admin roster-import screen.
VITE_DEFAULT_TEMP_PASSWORD=PNHSvote2026
